# 复制为 .env 后填入真实值；.env 不要提交到 git。
ZHIPU_API_KEY=your-zhipu-api-key-here
# 可选：覆盖 OpenAI 兼容接口地址（默认即下方地址）
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# 可选：显式指定源 / 目标仓库，覆盖 settings.yaml 里的默认（默认在项目内 repos/ 下）
# CCCL_REPO=/path/to/cccl
# ACCL_REPO=/path/to/accl
# 可选：显式指定 conda.sh，覆盖自动探测
# CONDA_SH=/path/to/miniconda3/etc/profile.d/conda.sh
