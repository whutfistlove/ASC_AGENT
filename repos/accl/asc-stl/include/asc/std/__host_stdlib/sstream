#ifndef ASC_STL_INCLUDE_ASC_STD___HOST_STDLIB_SSTREAM_
#define ASC_STL_INCLUDE_ASC_STD___HOST_STDLIB_SSTREAM_

#include "asc/std/__config"

#if defined(__CCE__)
#define ASC_DEVICE_CODE
#else
#include <sstream>
#endif

// [MIGRATION NOTE] The original CCCL header conditionally included the host's
// <sstream> via _CCCL_HOSTED(). ASC-STL does not have _CCCL_HOSTED, so we
// include <sstream> directly on the host side. On the device side (__CCE__),
// <sstream> is not available.

#endif // ASC_STL_INCLUDE_ASC_STD___HOST_STDLIB_SSTREAM_
